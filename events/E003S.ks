[chara_hide name="沙那子"　eye="eye1" mouth="mouth1" x="0.5" y="0.5"]

	//純一//
	「（いや、先生に、あと貸してくれた増田に、嘘はつけない！）」
	「ととと東京大学物語の６巻です！！！！！」
	「・・・あ。」

[chara_show name="増田"　eye="eye1" mouth="mouth1" x="0.5" y="0.5"]

	//増田//
	「純一！？図書室でどうしたんだいいきなり。」
	//純一//
	「いや。」
	//増田//
	「まーたあのえっちなシーン読みたくなったのかい。お盛んだねえ。」
	//純一//
	「その。」
	//増田//
	「ダメダメ。あれはね、今伊藤純平に貸してるんだ。」
	//純一//
	「違くて……」
	//増田//
	「知識と水とお色気漫画はね、独占してはいけないんだよ。純一クン。」
	//純一//
	「お前はお呼びじゃない！！！」

[fadeout]

	//純一//
	「（そのあと、二人で司書さんに説教された。）」
