  [if condition="choice_1==2"]
　　　　 //純一//
　　　　「僕はソースかなあ。」
	//桃子//
　[桃子　笑顔に変化]
　　　　「言うと思ったぁ……」
　　　　「ほんとあなたってって味濃いの好きよね。」
  [endif]

  [if condition="choice_1==3"]
　　　　 //純一//
　　　　「僕は醤油派だな。」
	//桃子//
　[桃子　驚き笑顔に変化]
　　　　「えー私と一緒だ！」
　[桃子　笑顔に変化]
　　　　「やったぁ……えへへ……」
  [endif]

  [if condition="choice_1==4"]
　　　　 //純一//
　　　　「無難にマヨネーズかなあ。」
	//桃子//
　[桃子　驚き顔に変化]
　　　　「＿＿マヨネーズ！？」
　　　　「あなたにそんな趣味があったとは……」
  [endif]

  [if condition="choice_1==5"]
　　　　 //純一//
　　　　「僕は塩かな。」
　[桃子　驚き顔に変化]
	//桃子//
