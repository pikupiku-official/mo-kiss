[choice_1 option1="ソース" option2="塩"　option3="醤油"　option4="マヨネーズ"　option5="ケチャップ"]

  [if condition="choice_1==1"]
　　　　 //純一//
　　　　「僕は塩かな。」
	//桃子//
　[桃子　驚き顔に変化]
　　　　「塩……！」
　　　　「貴方もなかなか通なとこあるのね……」
