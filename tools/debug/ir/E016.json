    {
      "id": "step_0014",
      "text": {
        "speaker": "桃子",
        "body": "わかる人にしかわからない、快速みたいな言葉もあって、一番言葉の集まる駅にしか止まらない、新幹線みたいな言葉もあります。",
        "scroll": false
      },
      "actions": [
        {
          "action": "chara_show",
