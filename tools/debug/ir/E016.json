    {
      "id": "step_0015",
      "text": {
        "speaker": "桃子",
        "body": "地下の暗闇を走る言葉もあります。",
        "scroll": true
      },
      "source_index": 21
    },
    {
      "id": "step_0016",
      "text": {
        "speaker": "桃子",
        "body": "地下から地下へ受け渡されるよこしまな想像力たち。",
        "scroll": true
      },
      "source_index": 22
    },
    {
      "id": "step_0017",
