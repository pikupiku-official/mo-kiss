          "action": "fadein",
          "params": {
            "time": 1.5
          },
          "animation": {
            "type": "once",
            "on_advance": "complete"
          }
        }
      ],
      "source_index": 36
    },
    {
      "id": "step_0027",
      "text": {
        "speaker": "純一",
        "body": "うげっ、朝からこの声はきっと…",
        "scroll": true
      },
      "source_index": 37
    },
    {
      "id": "step_0028",
      "text": {
        "speaker": "？？",
        "body": "お！純⼀じゃんか！",
        "scroll": true
      },
      "source_index": 38
    },
    {
      "id": "step_0029",
      "text": {
        "speaker": "純一",
        "body": "(あえて彼を放る。)",
        "scroll": true
      },
      "source_index": 39
    },
    {
      "id": "step_0030",
      "text": {
        "speaker": "？？",
        "body": "おーい！無視すんなって！…",
        "scroll": true
      },
      "actions": [
        {
          "action": "chara_show",
          "target": "増田",
          "params": {
            "torso": "増田",
            "name": "増田",
            "x": 0.5,
            "y": 0.5,
            "size": 1.0,
            "blink": true,
            "fade": 0.5,
            "eye": "eye1",
            "mouth": "mouth1",
            "brow": "",
            "cheek": ""
          },
          "animation": {
            "type": "once",
            "on_advance": "block"
          }
        }
      ],
      "source_index": 41
    },
    {
      "id": "step_0031",
      "text": {
        "speaker": "？？",
        "body": "いつからお前はそんな冷たい奴になったんだ？",
        "scroll": true
      },
      "source_index": 42
    },
    {
      "id": "step_0032",
      "text": {
        "speaker": "純一",
        "body": "むしろ増⽥が暑いんだよ",
        "scroll": true
      },
      "source_index": 43
    },
    {
      "id": "step_0033",
      "text": {
        "speaker": "純一",
        "body": "(僕は軽⼝を叩く。そうそう、こんな感じ。これがいつものムード。)",
        "scroll": true
      },
      "source_index": 44
    },
    {
      "id": "step_0034",
      "text": {
        "speaker": "純一",
        "body": "（彼は増⽥⼀樹。）",
        "scroll": true
      },
      "source_index": 45
    },
    {
      "id": "step_0035",
      "text": {
        "speaker": "純一",
        "body": "（かれこれ中学から５年間の付き合いになる。）",
        "scroll": true
      },
      "source_index": 46
    },
    {
      "id": "step_0036",
      "text": {
        "speaker": "増田",
        "body": "まったく、つれない顔するなよ",
        "scroll": true
      },
      "source_index": 47
    },
    {
      "id": "step_0037",
      "text": {
        "speaker": "純一",
        "body": "僕は昔から朝が弱いんだ。",
        "scroll": true
      },
      "source_index": 48
    },
    {
      "id": "step_0038",
      "text": {
        "speaker": "増田",
        "body": "そういやそうだったな。",
        "scroll": true
      },
      "source_index": 49
    },
    {
      "id": "step_0039",
      "text": {
        "speaker": "増田",
        "body": "修学旅行のときなんかお前…",
        "scroll": true
      },
      "source_index": 50
    },
    {
      "id": "step_0040",
      "text": {
        "speaker": "？？",
        "body": "あっ、じゅんいちだ。",
        "scroll": true,
        "force_female": true
      },
      "source_index": 51
    },
    {
      "id": "step_0041",
      "text": {
        "speaker": "？？",
        "body": "じゅんいち～～～～！",
        "scroll": true,
        "force_female": true
      },
      "source_index": 52
    },
    {
      "id": "step_0042",
      "text": {
        "speaker": "？？",
        "body": "おはよう！",
        "scroll": true,
        "force_female": true
      },
      "actions": [
        {
          "action": "chara_show",
          "target": "桃子",
          "params": {
            "torso": "桃子",
            "name": "桃子",
            "x": 0.5,
            "y": 0.5,
            "size": 1.0,
            "blink": true,
            "fade": 0.5,
            "eye": "eye1",
            "mouth": "mouth1",
            "brow": "",
            "cheek": ""
          },
          "animation": {
            "type": "once",
            "on_advance": "block"
          }
        }
      ],
      "source_index": 54
    },
    {
      "id": "step_0043",
      "text": {
        "speaker": "純一",
        "body": "やあ桃⼦。今⽇は遅いね。",
        "scroll": true
      },
      "source_index": 55
    },
    {
      "id": "step_0044",
      "text": {
        "speaker": "純一",
        "body": "（まるでお⽇様みたいな彼⼥は幼馴染の愛沼桃⼦。）",
        "scroll": true
      },
      "source_index": 56
    },
    {
      "id": "step_0045",
      "text": {
        "speaker": "純一",
        "body": "（僕とは⼩学⽣以来の幼馴染で、増⽥と共に⼀緒のクラスでもある。）",
        "scroll": true
      },
      "source_index": 57
    },
    {
      "id": "step_0046",
      "text": {
        "speaker": "桃子",
        "body": "うん。家族で古畑任三郎観ててね、夜更かししちゃったの。",
        "scroll": true
      },
      "source_index": 58
    },
    {
      "id": "step_0047",
      "text": {
        "speaker": "桃子",
        "body": "ふわぁ～。",
        "scroll": true
      },
      "source_index": 59
    },
    {
      "id": "step_0048",
      "text": {
        "speaker": "増田",
        "body": "でもさ、古畑は⽕曜だよな？",
        "scroll": true
      },
      "source_index": 60
    },
    {
      "id": "step_0049",
      "text": {
        "speaker": "増田",
        "body": "ってことは…",
        "scroll": true
      },
      "source_index": 61
    },
    {
      "id": "step_0050",
      "text": {
        "speaker": "増田",
        "body": "わざわざ録画して⾒てるのか？",
        "scroll": true
      },
      "source_index": 62
    },
    {
      "id": "step_0051",
      "text": {
        "speaker": "桃子",
        "body": "うん！",
        "scroll": true
      },
      "source_index": 63
    },
    {
      "id": "step_0052",
      "text": {
        "speaker": "桃子",
        "body": "うちはみんな三谷幸喜ファンだからね～。",
        "scroll": true
      },
      "source_index": 64
    },
    {
      "id": "step_0053",
      "text": {
        "speaker": "増田",
        "body": "桃子ん家は相変わらず仲良しだよな。",
        "scroll": true
      },
      "source_index": 65
    },
    {
      "id": "step_0054",
      "text": {
        "speaker": "桃子",
        "body": "えへへ…",
        "scroll": true
      },
      "source_index": 66
    },
    {
      "id": "step_0055",
      "text": {
        "speaker": "純一",
        "body": "(ニコニコ笑う彼⼥の横を、リーボックのスニーカーを履いた⽣徒が通り過ぎていくのが⾒えた。)",
        "scroll": true
      },
      "source_index": 67
    },
    {
      "id": "step_0056",
      "text": {
        "speaker": "純一",
        "body": "（それを⾒て、桃⼦の部活を思い出す。）",
        "scroll": true
      },
      "source_index": 68
    },
    {
      "id": "step_0057",
      "text": {
        "speaker": "純一",
        "body": "…そういえばさ桃⼦、テニス部は今⽇朝練じゃなかった？",
        "scroll": true
      },
      "source_index": 69
    },
    {
      "id": "step_0058",
      "text": {
        "speaker": "桃子",
        "body": "あっ…忘れてたぁ！",
        "scroll": true
      },
      "source_index": 70
    },
    {
      "id": "step_0059",
      "text": {
        "speaker": "純一",
        "body": "やっぱりそうだと思った。",
        "scroll": true
      },
      "source_index": 71
    },
    {
      "id": "step_0060",
      "text": {
        "speaker": "純一",
        "body": "桃子は天然だし。",
        "scroll": true
      },
      "source_index": 72
    },
    {
      "id": "step_0061",
      "text": {
        "speaker": "桃子",
        "body": "天然ですって？",
        "scroll": true
      },
      "source_index": 73
    },
    {
      "id": "step_0062",
      "text": {
        "speaker": "桃子",
        "body": "失礼ね〜〜",
        "scroll": true
      },
      "source_index": 74
    },
    {
      "id": "step_0063",
      "text": {
        "speaker": "増田",
        "body": "まあでも純⼀に救われたな！",
        "scroll": true
      },
      "source_index": 75
    },
    {
      "id": "step_0064",
      "text": {
        "speaker": "増田",
        "body": "桃⼦さんよ、早く⾏かないと遅刻するぞ？",
        "scroll": true
      },
      "source_index": 76
    },
    {
      "id": "step_0065",
      "text": {
        "speaker": "桃子",
        "body": "うん…遅刻したら〇〇先⽣に怒られちゃう。",
        "scroll": true
      },
      "source_index": 77
    },
    {
      "id": "step_0066",
      "text": {
        "speaker": "純一",
        "body": "(まるで久しぶりに運動させられている飼い⽝みたいだ。)",
        "scroll": true
      },
      "source_index": 78
    },
    {
      "id": "step_0067",
      "text": {
        "speaker": "純一",
        "body": "（けど、僕は桃⼦が他の⼈たちに笑われてる姿はあまり⾒たくないな。）",
        "scroll": true
      },
      "source_index": 79
    },
    {
      "id": "step_0068",
      "text": {
        "speaker": "純一",
        "body": "今⾛っていけば間に合うと思うよ。",
        "scroll": true
      },
      "source_index": 80
    },
    {
      "id": "step_0069",
      "text": {
        "speaker": "桃子",
        "body": "そうかな？",
        "scroll": true
      },
      "source_index": 81
    },
    {
      "id": "step_0070",
      "text": {
        "speaker": "桃子",
        "body": "……",
        "scroll": true
      },
      "source_index": 82
    },
    {
      "id": "step_0071",
      "text": {
        "speaker": "桃子",
        "body": "やっぱりせっかく純⼀が教えてくれたことだし、頑張ってみる！",
        "scroll": true
      },
      "source_index": 83
    },
    {
      "id": "step_0072",
      "text": {
        "speaker": "増田",
        "body": "…結局、俺ら⼆⼈ってことだ。なあ純⼀。",
        "scroll": true
      },
      "actions": [
        {
          "action": "chara_hide",
          "target": "桃子",
          "params": {
            "fade": 0.5
          },
          "animation": {
            "type": "once",
            "on_advance": "block"
          }
        }
      ],
      "source_index": 85
    },
    {
      "id": "step_0073",
      "text": {
        "speaker": "純一",
        "body": "そうだね…",
        "scroll": true
      },
      "source_index": 86
    },
    {
      "id": "step_0074",
      "text": {
        "speaker": "増田",
        "body": "よし、そうと決まればスピッツでも歌うか？",
        "scroll": true
      },
      "source_index": 87
    },
    {
      "id": "step_0075",
      "text": {
        "speaker": "純一",
        "body": "(いつもの増⽥リサイタルが始まりそうだ。今回はどの曲だろうか。)",
        "scroll": true
      },
      "source_index": 88
    },
    {
      "id": "step_0076",
      "text": {
        "speaker": "純一",
        "body": "リクエストは受け付けてますか？",
        "scroll": true
      },
      "source_index": 89
    },
    {
      "id": "step_0077",
      "text": {
        "speaker": "増田",
        "body": "おう。何がいいんだ。",
        "scroll": true
      },
      "source_index": 90
    },
    {
      "id": "step_0078",
      "text": {
        "speaker": "純一",
        "body": "なんだっけ、さっき増⽥が⼝ずさんでたやつ。",
        "scroll": true
      },
      "source_index": 91
    },
    {
      "id": "step_0079",
      "text": {
        "speaker": "純一",
        "body": "あれ。",
        "scroll": true
      },
      "source_index": 92
    },
    {
      "id": "step_0080",
      "text": {
        "speaker": "増田",
        "body": "⽇なたの窓に憧れてか？",
        "scroll": true
      },
      "source_index": 93
    },
    {
      "id": "step_0081",
      "text": {
        "speaker": "増田",
        "body": "純⼀もセンスがいいねぇ！",
        "scroll": true
      },
      "source_index": 94
    },
    {
      "id": "step_0082",
      "text": {
        "speaker": "桃子",
        "body": "純⼀〜〜〜〜〜 ありがとね〜〜〜！！",
        "scroll": true
      },
      "source_index": 95
    },
    {
      "id": "step_0083",
      "text": {
        "speaker": "純一",
        "body": "え？",
        "scroll": true
      },
      "source_index": 96
    },
    {
      "id": "step_0084",
      "text": {
        "speaker": "増田",
        "body": "あ？",
        "scroll": true
      },
      "source_index": 97
    },
    {
      "id": "step_0085",
      "text": {
        "speaker": "純一",
        "body": "(僕らの声は同時だった。突然の⼤声に驚いて、⾜を⽌める。そして辺りを⾒回す。)",
        "scroll": true
      },
      "source_index": 98
    },
    {
      "id": "step_0086",
      "text": {
        "speaker": "増田",
        "body": "純⼀、あそこだ。⾒ろよほら、校⾨の前を！",
        "scroll": true
      },
      "source_index": 99
    },
    {
      "id": "step_0087",
      "text": {
        "speaker": "純一",
        "body": "(急いで視線を増⽥が指差す校⾨の⽅に向ける。)",
        "scroll": true
      },
      "source_index": 100
    },
    {
      "id": "step_0088",
      "text": {
        "speaker": "純一",
        "body": "(視線の先にはとびきりの笑顔で⼿を振る桃⼦がいる。)",
        "scroll": true
      },
      "actions": [
        {
          "action": "chara_show",
          "target": "桃子",
          "params": {
            "torso": "桃子",
            "name": "桃子",
            "x": 0.5,
            "y": 0.5,
            "size": 1.0,
            "blink": true,
            "fade": 0.5,
            "eye": "eye1",
            "mouth": "mouth1",
            "brow": "",
            "cheek": ""
          },
          "animation": {
            "type": "once",
            "on_advance": "block"
          }
        }
      ],
      "source_index": 102
    },
    {
      "id": "step_0089",
      "text": {
        "speaker": "純一",
        "body": "(僕は正直⼾惑いつつも、急いで彼⼥に⼿を振り返す。)",
        "scroll": true
      },
      "source_index": 103
    },
    {
      "id": "step_0090",
      "text": {
        "speaker": "増田",
        "body": "頑張れよ～！",
        "scroll": true
      },
      "source_index": 104
    },
    {
      "id": "step_0091",
      "text": {
        "speaker": "純一",
        "body": "(増⽥の声の後、桃⼦が校⾨の中に駆け込んでいく姿が⼩さく⾒えた。)",
        "scroll": true
      },
      "actions": [
        {
          "action": "chara_hide",
          "target": "桃子",
          "params": {
            "fade": 0.5
          },
          "animation": {
            "type": "once",
            "on_advance": "block"
          }
        }
      ],
      "source_index": 106
    },
    {
      "id": "step_0092",
      "text": {
        "speaker": "増田",
        "body": "あいつたまにああいうことするよな。",
        "scroll": true
      },
      "source_index": 107
    },
    {
      "id": "step_0093",
      "text": {
        "speaker": "増田",
        "body": "素直かつ大胆っていうかさあ。",
        "scroll": true
      },
      "source_index": 108
    },
    {
      "id": "step_0094",
      "text": {
        "speaker": "純一",
        "body": "…",
        "scroll": true
      },
      "source_index": 109
    },
    {
      "id": "step_0095",
      "text": {
        "speaker": "増田",
        "body": "あの性格がクラスの奴らを惹きつけているんだろうな。",
        "scroll": true
      },
      "source_index": 110
    },
    {
      "id": "step_0096",
      "text": {
        "speaker": "純一",
        "body": "…",
        "scroll": true
      },
      "source_index": 111
    },
    {
      "id": "step_0097",
      "text": {
        "speaker": "増田",
        "body": "なあ、純⼀。",
        "scroll": true
      },
      "source_index": 112
    },
    {
      "id": "step_0098",
      "text": {
        "speaker": "純一",
        "body": "…",
        "scroll": true
      },
      "source_index": 113
    },
    {
      "id": "step_0099",
      "text": {
        "speaker": "増田",
        "body": "純⼀? おい、どうしたんだよ。",
        "scroll": true
      },
      "source_index": 114
    },
    {
      "id": "step_0100",
      "text": {
        "speaker": "純一",
        "body": "あ、ああ… えーとクラスがなんだっけ。",
        "scroll": true
      },
      "source_index": 115
    },
    {
      "id": "step_0101",
      "text": {
        "speaker": "増田",
        "body": "なんだよ全く。",
        "scroll": true
      },
      "source_index": 116
    },
    {
      "id": "step_0102",
      "text": {
        "speaker": "増田",
        "body": "俺の話も聞かず、⽴ち⽌まってボーッとしやがって。",
        "scroll": true
      },
      "source_index": 117
    },
    {
      "id": "step_0103",
      "text": {
        "speaker": "増田",
        "body": "ホントにお前は朝が弱いんだからさ、呆れるよ。",
        "scroll": true
      },
      "source_index": 118
    },
    {
      "id": "step_0104",
      "text": {
        "speaker": "純一",
        "body": "(増⽥の⾔う通り、全く彼の話が頭に⼊ってこなかった。)",
        "scroll": true
      },
      "source_index": 119
    },
    {
      "id": "step_0105",
      "text": {
        "speaker": "純一",
        "body": "(正直に⾔うと、坂上に⽴ち笑顔で⼿を振る彼⼥の姿、彼⼥を照らす朝の光。)",
        "scroll": true
      },
      "source_index": 120
    },
    {
      "id": "step_0106",
      "text": {
        "speaker": "純一",
        "body": "(その景⾊に⽬が離せなかったからだ。)",
        "scroll": true
      },
      "source_index": 121
    },
    {
      "id": "step_0107",
      "text": {
        "speaker": "純一",
        "body": "(それは映画の導⼊シーンみたいだった。)",
        "scroll": true
      },
      "source_index": 122
    },
    {
      "id": "step_0108",
      "text": {
        "speaker": "純一",
        "body": "増田。",
        "scroll": true
      },
      "source_index": 123
    },
    {
      "id": "step_0109",
      "text": {
        "speaker": "増田",
        "body": "はあ。",
        "scroll": true
      },
      "source_index": 124
    },
    {
      "id": "step_0110",
      "text": {
        "speaker": "純一",
        "body": "僕が今考えていたことを知りたい？",
        "scroll": true
      },
      "source_index": 125
    },
    {
      "id": "step_0111",
      "text": {
        "speaker": "増田",
        "body": "早く教えろよ。",
        "scroll": true
      },
      "source_index": 126
    },
    {
      "id": "step_0112",
      "text": {
        "speaker": "純一",
        "body": "(僕は⽌めていた⾜を踏み出しながら、整理した答えを増⽥に返す。)",
        "scroll": true
      },
      "source_index": 127
    },
    {
      "id": "step_0113",
      "text": {
        "speaker": "純一",
        "body": "朝も捨てたもんじゃないってことあ。",
        "scroll": true
      },
      "source_index": 128
    },
    {
      "id": "step_0114",
      "actions": [
